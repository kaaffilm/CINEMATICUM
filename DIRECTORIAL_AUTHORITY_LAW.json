{
  "schema_version": "cinematicum.directorial_authority_law.v1",
  "authority": "director",
  "director_is_not_model_operator": true,
  "director_controls": [
    "film_thesis",
    "audience_wound",
    "script_lock",
    "shot_function",
    "performance_truth",
    "retake_decision",
    "final_cut_acceptance"
  ],
  "director_may_reject": [
    "beautiful_but_wrong_shot",
    "technically_valid_but_dead_performance",
    "high_quality_image_without_dramatic_function",
    "render_that_breaks_film_thesis"
  ],
  "model_output_status": "raw_material_only",
  "pass_condition": "DIRECTORIAL_AUTHORITY_LAW_PASS"
}
