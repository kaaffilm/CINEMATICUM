    "current_zero_ledger_further_non_capability_seals_required": false
  },
  "redundancy_rule": {
    "additional_non_star_seal_default_forbidden": true,
    "additional_non_star_seal_allowed_only_if_required_to_unblock_real_intake": true,
    "additional_non_star_seal_must_name_unblocked_real_intake_gate": true,
    "additional_non_star_seal_must_not_reclassify_current_zero_ledger": true,
