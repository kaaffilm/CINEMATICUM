{
  "object_type": "CINEMATICUM_FINAL_CUT_TIMELINE_LOCK_SCHEMA",
  "schema_version": "cinematicum.final_cut_timeline_lock_schema.v1",
  "boundary": "SCHEMA_ONLY_NO_TIMELINE_OBJECT",
  "required_fields": [
    "case_id",
    "timeline_lock_id",
    "timeline_digest",
    "cut_list_digest",
    "shot_function_map_digest",
    "silence_map_digest",
    "duration_frames",
    "frame_rate",
    "locked_at_utc",
    "locked_by_authority_id"
  ],
  "required_assertions": [
    "timeline_is_identified_by_digest",
    "timeline_lock_does_not_embed_media",
    "timeline_lock_does_not_issue_film"
  ],
  "forbidden_fields": [
    "raw_video",
    "raw_audio",
    "render_cache",
    "timeline_private_assets",
    "generation_prompt_chain"
  ]
}
