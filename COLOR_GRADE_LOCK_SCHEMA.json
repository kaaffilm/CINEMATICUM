    "grade_is_digest_bound",
    "grade_lock_does_not_embed_image",
    "grade_lock_does_not_issue_film"
  ],
  "forbidden_fields": [
    "raw_image",
    "stills",
    "lut_file_bytes",
    "private_assets",
    "render_cache"
  ]
}
