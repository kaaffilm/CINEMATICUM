  "boundary": "SCHEMA_ONLY_NO_IMAGE_OBJECT",
  "required_fields": [
    "case_id",
    "color_grade_lock_id",
    "grade_digest",
    "look_boundary",
    "locked_by_authority_id",
    "locked_at_utc",
    "supersedes_grade_lock_id"
