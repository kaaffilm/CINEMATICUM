{
  "schema_version": "cinematicum.issuance_docket.v1",
  "institution": "CINEMATICUM",
  "root_sentence": "CINEMATICUM issues admissible motion pictures.",
  "docket_authority": "motion_picture_issuance",
  "issued_object": "admissible_motion_picture",
  "first_case": "CASE_001_THE_LAST_RENDER",
  "first_case_title": "THE LAST RENDER",
  "issuance_is_not_export": true,
  "issuance_is_not_upload": true,
  "issuance_is_not_generation": true,
  "case_states": [
    "registered_under_jurisdiction",
    "development_admitted",
    "preproduction_admitted",
    "production_admitted",
    "editorial_admitted",
    "locked_picture_candidate",
    "final_mix_candidate",
    "final_grade_candidate",
    "release_candidate",
    "issued_admissible_motion_picture",
    "terminally_closed"
  ],
  "issuance_requires": [
    "audience_wound",
    "film_thesis",
    "director_authority",
    "script_lock",
    "shot_function_chain",
    "selected_take_ledger",
    "timeline_authority",
    "final_cut_lock",
    "final_mix_lock",
    "final_grade_lock",
    "release_manifest",
    "public_release_object",
    "outsider_replay",
    "terminal_closure"
  ],
  "inadmissible_if": [
    "only_media_file_exists",
    "only_prompt_exists",
    "only_model_output_exists",
    "timeline_missing",
    "director_authority_missing",
    "shot_function_missing",
    "release_proof_missing",
    "outsider_replay_missing"
  ],
  "local_only": true,
  "paid_api_allowed": false,
  "cloud_render_allowed": false,
  "raw_media_in_git": false,
  "model_weights_in_git": false,
  "pass_condition": "CINEMATICUM_ISSUANCE_DOCKET_PASS"
}
