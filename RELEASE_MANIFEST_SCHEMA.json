{
  "object_type": "CINEMATICUM_RELEASE_MANIFEST_SCHEMA",
  "schema_version": "cinematicum.release_manifest_schema.v1",
  "boundary": "SCHEMA_ONLY_NO_RELEASE_ARTIFACT",
  "required_fields": [
    "case_id",
    "release_candidate_id",
    "director_acceptance_id",
    "locked_picture_id",
    "final_cut_timeline_id",
    "final_mix_lock_id",
    "final_grade_lock_id",
    "media_hash_manifest_id",
    "outsider_replay_bundle_id",
    "created_at_utc"
  ],
  "forbidden_fields": [
    "raw_media_blob",
    "embedded_video",
    "embedded_audio",
    "model_weights",
    "prompt_chain_secret",
    "private_key",
    "cloud_render_token"
  ],
  "manifest_rule": "The release manifest may identify admissible release artifacts by digest and authority object, but must not embed media or secrets."
}
