{
  "object_type": "CINEMATICUM_OBJECT_REGISTRY_LAW",
  "schema_version": "cinematicum.object_registry_law.v1",
  "institution": "CINEMATICUM",
  "root_sentence": "CINEMATICUM issues admissible motion pictures.",
  "purpose": "Define the machine-readable object registry and surface-class system for the CINEMATICUM repository.",
  "registry_owner": "CINEMATICUM_OBJECT_REGISTRY.json",
  "surface_class_catalog_owner": "CINEMATICUM_SURFACE_CLASS_CATALOG.json",
  "current_state_owner": "CINEMATICUM_CURRENT_STATE_INDEX.json",
  "case_current_state_owner": "CASES/CASE_001_THE_LAST_RENDER/CURRENT_CASE_STATE.json",
  "object_registry_rule": "Every critical CINEMATICUM JSON object must be discoverable by path, object type, class, authority level, and current-truth posture.",
  "registry_does_not": [
    "issue a film",
    "make a release candidate ready",
    "admit media",
    "execute replay",
    "produce a verdict",
    "override current state"
  ],
  "required_surface_classes": [
    "LAW_OBJECT",
    "SCHEMA_OBJECT",
    "ACTIVE_CURRENT_STATE",
    "LAYER_STATUS_RECORD",
    "CASE_RECORD",
    "BOUNDARY_DOCUMENT",
    "VERIFICATION_MANIFEST",
    "PROGRESSION_GRAPH"
  ],
  "forbidden_registry_conditions": [
    "unregistered critical JSON object",
    "two active current-state owners for the same case",
    "schema object marked as issued object",
    "layer-status record marked as current truth",
    "registry asserting release candidate readiness",
    "registry asserting issuance",
    "registry admitting media"
  ]
}
