{
  "object_type": "CINEMATICUM_SOUND_MIX_LOCK_SCHEMA",
  "schema_version": "cinematicum.sound_mix_lock_schema.v1",
  "boundary": "SCHEMA_ONLY_NO_AUDIO_OBJECT",
  "required_fields": [
    "case_id",
    "sound_mix_lock_id",
    "mix_digest",
    "mix_role",
    "locked_by_authority_id",
    "locked_at_utc",
    "supersedes_mix_lock_id"
  ],
  "required_assertions": [
    "mix_is_digest_bound",
    "mix_lock_does_not_embed_audio",
    "mix_lock_does_not_issue_film"
  ],
  "forbidden_fields": [
    "raw_audio",
    "stems",
    "private_assets",
    "cloud_render_token"
  ]
}
