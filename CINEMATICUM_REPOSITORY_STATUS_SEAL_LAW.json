{
  "object_type": "CINEMATICUM_REPOSITORY_STATUS_SEAL_LAW",
  "schema_version": "cinematicum.repository_status_seal_law.v1",
  "institution": "CINEMATICUM",
  "root_sentence": "CINEMATICUM issues admissible motion pictures.",
  "purpose": "Define the public repository status seal as a bounded summary of current CINEMATICUM object state.",
  "seal_owner": "CINEMATICUM_REPOSITORY_STATUS_SEAL.json",
  "public_document_owner": "PUBLIC_STATUS.md",
  "current_state_owner": "CINEMATICUM_CURRENT_STATE_INDEX.json",
  "case_current_state_owner": "CASES/CASE_001_THE_LAST_RENDER/CURRENT_CASE_STATE.json",
  "verification_owner": "scripts/verify-all.sh",
  "registry_freshness_owner": "scripts/verify-object-registry-fresh.sh",
  "seal_rule": "The repository status seal may summarize current object state, but it may not outrank the current-state index or case current-state object.",
  "seal_must_assert": {
    "current_state": "OUTSIDER_REPLAY_BUNDLE_LAW_DECLARED",
    "release_candidate_ready": false,
    "issued": false,
    "media_present": false,
    "outsider_replay_passed": false,
    "verify_all_pass_required": true,
    "object_registry_fresh_required": true
  },
  "seal_does_not": [
    "issue a film",
    "make the case release-candidate-ready",
    "admit media",
    "execute replay",
    "produce an admissibility verdict",
    "create terminal closure",
    "override the object registry",
    "override the current-state index"
  ]
}
