{
  "object_type": "CINEMATICUM_ADMISSIBILITY_VERDICT_SCHEMA",
  "schema_version": "cinematicum.admissibility_verdict_schema.v1",
  "boundary": "SCHEMA_ONLY_NO_VERDICT",
  "allowed_verdicts": [
    "ADMISSIBLE",
    "INADMISSIBLE",
    "BLOCKED",
    "UNRESOLVED"
  ],
  "required_fields": [
    "verdict_id",
    "case_id",
    "bundle_id",
    "verdict",
    "verdict_authority",
    "verdict_basis",
    "checked_objects",
    "issued_film",
    "release_candidate_ready",
    "media_present",
    "outsider_replay_passed",
    "created_at_utc"
  ],
  "required_assertions": [
    "verdict_must_reference_bundle",
    "verdict_must_reference_checked_objects",
    "verdict_does_not_embed_media",
    "verdict_does_not_issue_film_unless_motion_picture_issuance_act_exists"
  ],
  "forbidden_fields": [
    "embedded_media",
    "raw_footage",
    "private_key",
    "unbounded_ai_judgment",
    "social_trust_only"
  ]
}
